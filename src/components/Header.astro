---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';

// Logonun adresi (YouTube profil resmin)
const LOGO_URL = "https://yt3.ggpht.com/2sgkRjrr89YgkjgGoN-YxOuTDPthLN22os716aj_ASqTPhFRCtEJKU0zqK71f16IruiLUESMRgc=s48-c-k-c0x00ffffff-no-rj"; 
// Senin YouTube Kanal Linkin
const YOUTUBE_KANAL_LINKI = "https://www.youtube.com/@iyibilgilernet"; 
---

<header>
    <nav style="display: flex; align-items: center; justify-content: space-between;">
        <h2 style="margin: 0;">
            <a href="/" style="display: flex; align-items: center; gap: 10px; text-decoration: none; color: inherit;">
                <img src={LOGO_URL} alt="Logo" style="height: 40px; border-radius: 50%;" />
                {SITE_TITLE}
            </a>
        </h2>

        <div class="internal-links" style="display: flex; align-items: center; gap: 15px;">
            <HeaderLink href="/">Ana Sayfa</HeaderLink>
            <HeaderLink href="/blog">Blog</HeaderLink>
            
            <a href={YOUTUBE_KANAL_LINKI} target="_blank" style="background: #ff0000; color: white; padding: 5px 12px; border-radius: 20px; text-decoration: none; font-size: 14px; font-weight: bold;">
                Abone Ol
            </a>
        </div>
    </nav>
</header>
